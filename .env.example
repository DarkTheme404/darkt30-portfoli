# SMTP для реальной отправки писем
# Без SMTP — заявки сохраняются в server/contact/leads.json и логируются
# Для Gmail:
# 1. Включи 2FA: https://myaccount.google.com/security
# 2. App Password: https://myaccount.google.com/apppasswords
# 3. Укажи ниже:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=artem.kurskiy.04@gmail.com
# SMTP_PASS=xxxx-xxxx-xxxx

# Yandex (если почта на yandex.ru):
